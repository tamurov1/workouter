generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url       = env("POSTGRES_URL")
  directUrl = env("POSTGRES_URL")
}

enum UserRole {
  TRAINEE
  TRAINER
}

enum JoinRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model User {
  id                   String             @id @default(cuid())
  name                 String
  email                String             @unique
  passwordHash         String
  role                 UserRole?
  bio                  String             @default("")
  avatarData           String?
  points               Int                @default(0)
  sessions             Session[]
  trainedGroups        Group[]            @relation("TrainerGroups")
  groupMemberships     GroupMember[]
  groupJoinRequests    GroupJoinRequest[]
  assignedWorkouts     Workout[]          @relation("AssignedWorkouts")
  createdWorkouts      Workout[]          @relation("CreatedWorkouts")
  workoutTemplates     WorkoutTemplate[]
  completedExercises   WorkoutExercise[]  @relation("CompletedExercises")
  completedWorkoutLogs WorkoutCompletion[]
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Group {
  id           String             @id @default(cuid())
  name         String
  description  String             @default("")
  trainerId    String
  trainer      User               @relation("TrainerGroups", fields: [trainerId], references: [id], onDelete: Cascade)
  memberships  GroupMember[]
  joinRequests GroupJoinRequest[]
  workouts     Workout[]
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([trainerId])
}

model GroupMember {
  id        String   @id @default(cuid())
  userId    String
  groupId   String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  joinedAt  DateTime @default(now())

  @@unique([userId, groupId])
  @@index([groupId])
}

model GroupJoinRequest {
  id          String            @id @default(cuid())
  userId      String
  groupId     String
  status      JoinRequestStatus @default(PENDING)
  reviewedAt  DateTime?
  createdAt   DateTime          @default(now())
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  group       Group             @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId, status])
  @@index([userId])
}

model Workout {
  id             String              @id @default(cuid())
  title          String
  dayLabel       String
  deadline       DateTime
  isArchived     Boolean             @default(false)
  groupId        String
  traineeId      String
  trainerId      String
  group          Group               @relation(fields: [groupId], references: [id], onDelete: Cascade)
  trainee        User                @relation("AssignedWorkouts", fields: [traineeId], references: [id], onDelete: Cascade)
  trainer        User                @relation("CreatedWorkouts", fields: [trainerId], references: [id], onDelete: Cascade)
  exercises      WorkoutExercise[]
  completions    WorkoutCompletion[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([groupId])
  @@index([traineeId, deadline])
  @@index([isArchived, deadline])
}

model WorkoutExercise {
  id                 String              @id @default(cuid())
  workoutId          String
  name               String
  setNumber          Int                 @default(1)
  sets               Int
  reps               Int
  rpe                Float
  load               Float               @default(0)
  explicitIntensity  Float?
  actualRpe          Float?
  completedReps      Int?
  intensity          Float               @default(0)
  isCompleted        Boolean             @default(false)
  volume             Int
  sortOrder          Int
  completedByUserId  String?
  completedAt        DateTime?
  workout            Workout             @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  completedByUser    User?               @relation("CompletedExercises", fields: [completedByUserId], references: [id], onDelete: SetNull)

  @@index([workoutId, sortOrder])
  @@index([workoutId, name, sortOrder])
}

model WorkoutCompletion {
  id          String   @id @default(cuid())
  workoutId   String
  userId      String
  completedAt DateTime @default(now())
  workout     Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workoutId, userId])
  @@index([userId, completedAt])
}

model WorkoutTemplate {
  id          String                    @id @default(cuid())
  name        String
  title       String
  dayLabel    String
  trainerId   String
  trainer     User                      @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  exercises   WorkoutTemplateExercise[]
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt

  @@index([trainerId, createdAt])
}

model WorkoutTemplateExercise {
  id            String            @id @default(cuid())
  templateId    String
  name          String
  setNumber     Int               @default(1)
  sets          Int
  reps          Int
  rpe           Float
  load          Float             @default(0)
  explicitIntensity Float?
  intensity     Float             @default(0)
  volume        Int
  sortOrder     Int
  template      WorkoutTemplate   @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId, sortOrder])
  @@index([templateId, name, sortOrder])
}
